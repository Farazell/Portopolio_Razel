{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Buka index.html Langsung (Tanpa Server)",
            "file": "${workspaceFolder}/Portopolio/index.html"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Hubungkan ke Local Server (Port 8000)",
